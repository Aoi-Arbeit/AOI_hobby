];

let activeId = templates[0].id;

function updateUI() {
    const navButtons = document.getElementById('nav-buttons');
    const posterContainer = document.getElementById('poster-container');
    const infoPanel = document.getElementById('info-panel');
    const activeData = templates.find(t => t.id === activeId);

    // Update Navigation
    navButtons.innerHTML = '';
    templates.forEach(t => {
        const isActive = t.id === activeId;
        const btn = document.createElement('button');
        btn.className = `w-full text-left px-4 py-3 rounded-xl transition-all border ${isActive ? 'bg-indigo-600 text-white shadow-lg border-indigo-600' : 'bg-white text-slate-600 hover:bg-slate-50 border-slate-200'}`;
        btn.innerHTML = `
            <div class="flex flex-col">
                <span class="text-[10px] uppercase font-bold opacity-60">${t.type}</span>
                <span class="font-bold">${t.name}</span>
            </div>
        `;
        btn.onclick = () => {
            activeId = t.id;
            updateUI();
        };
        navButtons.appendChild(btn);
    });

    // Update Poster
    posterContainer.innerHTML = activeData.html;

    // Update Info Panel
    infoPanel.innerHTML = `
        <div class="fade-in">
            <span class="inline-block bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest mb-4">Template Guide</span>
            <h2 class="text-2xl font-bold text-slate-800 mb-4">${activeData.name}</h2>
            
            <p class="text-slate-600 mb-6 leading-relaxed">${activeData.description}</p>
            
            <div class="space-y-6">
                <section>
                    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">おすすめの用途</h3>
                    <p class="text-slate-800 font-medium">${activeData.useCase}</p>
                </section>
                
                <div class="grid grid-cols-2 gap-4">
                    <section class="bg-emerald-50 p-3 rounded-lg">
                        <h3 class="text-[10px] font-bold text-emerald-600 uppercase mb-1">メリット</h3>
                        <p class="text-xs text-emerald-800">${activeData.pros}</p>
                    </section>
                    <section class="bg-rose-50 p-3 rounded-lg">
                        <h3 class="text-[10px] font-bold text-rose-600 uppercase mb-1">デメリット</h3>
                        <p class="text-xs text-rose-800">${activeData.cons}</p>
                    </section>
                </div>

                <section class="bg-indigo-600 text-white p-5 rounded-xl">
                    <h3 class="text-xs font-bold opacity-80 uppercase mb-2">成功のポイント</h3>
                    <p class="text-sm font-bold leading-relaxed">${activeData.key}</p>
                </section>
            </div>
        </div>
    `;
}

// Initial Render
document.addEventListener('DOMContentLoaded', updateUI);
</script>

</body>
</html>
